# Copy to .env and edit as needed.

# Hosted PostgreSQL connection string from Neon, Supabase, Prisma Postgres,
# or another managed provider. Do not commit the real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Iron-session encryption key. Generate one with:  openssl rand -hex 32
SESSION_SECRET="change-me-32-bytes-of-random-data-please"

# Public app URL used in verification/reset email links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Open Library is free / no key. Override only if you swap to Google Books.
ISBN_LOOKUP_PROVIDER="openlibrary"

# Where uploaded book photos go. For dev we use a local folder; in
# production this should be S3-compatible object storage.
UPLOAD_BACKEND="local"
LOCAL_UPLOAD_DIR=".uploads"
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"

# Email sender for verification + password reset. Leave SMTP_HOST blank to use
# mock email mode; set SMTP_* to send real email.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="BookBridge <noreply@bookbridge.local>"
EMAIL_DIGEST_ENABLED="false"

# Sale price cap in VND (default 50,000). Enforced server-side.
SALE_PRICE_CAP_VND=50000

# Bearer secret for every /api/cron/* endpoint.
CRON_SECRET=""

# Daily attributed book bulletins. Open Library, Library of Congress,
# Project Gutenberg, Internet Archive, Guardian Books, NPR Book of the Day,
# and AP Books & Literature work without keys. NYT Best Sellers is enabled
# only when this optional key exists.
BULLETIN_COMMUNITY_NAME="Book News & Discoveries"
BULLETIN_AUTHOR_EMAIL="admin@bookbridge.local"
NYT_BOOKS_API_KEY=""
